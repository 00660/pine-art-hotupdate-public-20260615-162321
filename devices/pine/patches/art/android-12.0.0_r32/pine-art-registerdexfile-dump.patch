+static bool PineIsPackageNameChar(char ch) {
+  return (ch >= 'a' && ch <= 'z') ||
+         (ch >= 'A' && ch <= 'Z') ||
+         (ch >= '0' && ch <= '9') ||
+         ch == '.' ||
+         ch == '_';
+}
+
+static bool PineGetCurrentPackageName(std::string* package_name) {
+  char cmdline[256] = {};
+  int fd = open("/proc/self/cmdline", O_RDONLY | O_CLOEXEC);
+  if (fd < 0) {
+    return false;
+  }
+  ssize_t count = read(fd, cmdline, sizeof(cmdline) - 1);
+  close(fd);
+  if (count <= 0) {
+    return false;
+  }
+  size_t len = strnlen(cmdline, static_cast<size_t>(count));
+  if (len == 0) {
+    return false;
+  }
+  std::string process_name(cmdline, len);
+  size_t suffix_pos = process_name.find(':');
+  if (suffix_pos != std::string::npos) {
+    process_name.resize(suffix_pos);
+  }
+  if (process_name.empty()) {
+    return false;
+  }
+  for (char ch : process_name) {
+    if (!PineIsPackageNameChar(ch)) {
+      return false;
+    }
+  }
+  *package_name = process_name;
+  return true;
+}
+
+static bool PineArtDexDumpEnabledForPackage(const std::string& package_name) {
+  const bool enabled = android::base::GetBoolProperty("persist.sys.pine_art_dexdump", false) ||
+                       android::base::GetBoolProperty("debug.pine.art_dexdump", false);
+  if (!enabled) {
+    return false;
+  }
+  std::string target =
+      android::base::GetProperty("persist.sys.pine_art_dexdump_pkg", "");
+  if (target.empty()) {
+    target = android::base::GetProperty("debug.pine.art_dexdump_pkg", "");
+  }
+  return target.empty() || target == package_name;
+}
+
+static bool PineEnsureDir(const std::string& path) {
+  // Use 0777 for /data/temp and its subdirs to allow cross-app access
+  mode_t mode = (path.find("/data/temp") == 0) ? 0777 : 0700;
+  if (mkdir(path.c_str(), mode) == 0) {
+    chmod(path.c_str(), mode);  // Ensure permissions even if dir exists
+    return true;
+  }
+  if (errno == EEXIST) {
+    return true;
+  }
+  PLOG(WARNING) << "pine ART dexdump mkdir failed: " << path;
+  return false;
+}
+
+static uint32_t PineReadLe32(const uint8_t* data) {
+  return static_cast<uint32_t>(data[0]) |
+         (static_cast<uint32_t>(data[1]) << 8) |
+         (static_cast<uint32_t>(data[2]) << 16) |
+         (static_cast<uint32_t>(data[3]) << 24);
+}
+
+static void PineWriteDexMeta(const std::string& path,
+                             const DexFile& dex_file,
+                             const std::string& package_name,
+                             uint32_t checksum) {
+  int fd = open(path.c_str(), O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC, 0600);
+  if (fd < 0) {
+    PLOG(WARNING) << "pine ART dexdump meta open failed: " << path;
+    return;
+  }
+  std::string meta = StringPrintf("package=%s\npid=%d\nlocation=%s\nsize=%zu\nchecksum=%08x\n",
+                                  package_name.c_str(),
+                                  getpid(),
+                                  dex_file.GetLocation().c_str(),
+                                  dex_file.Size(),
+                                  checksum);
+  const char* data = meta.data();
+  size_t remaining = meta.size();
+  while (remaining != 0u) {
+    ssize_t written = write(fd, data, remaining);
+    if (written <= 0) {
+      PLOG(WARNING) << "pine ART dexdump meta write failed: " << path;
+      break;
+    }
+    data += written;
+    remaining -= static_cast<size_t>(written);
+  }
+  close(fd);
+}
+
+static void PineMaybeDumpRegisteredDexFile(const DexFile& dex_file) {
+  const uint8_t* begin = dex_file.Begin();
+  const size_t size = dex_file.Size();
+  if (begin == nullptr || size < 0x70u || memcmp(begin, "dex\n", 4) != 0) {
+    return;
+  }
+
+  std::string package_name;
+  if (!PineGetCurrentPackageName(&package_name) ||
+      !PineArtDexDumpEnabledForPackage(package_name)) {
+    return;
+  }
+
+  const uint32_t checksum = PineReadLe32(begin + 8);
+  const std::string base_dir = "/data/temp/pine-art-dumps";
+  const std::string dump_dir = StringPrintf("%s/%s", base_dir.c_str(), package_name.c_str());
+  if (!PineEnsureDir("/data/temp") || !PineEnsureDir(base_dir) || !PineEnsureDir(dump_dir)) {
+    return;
+  }
+
+  const std::string dex_path = StringPrintf("%s/pid%d_%zu_%08x.dex",
+                                            dump_dir.c_str(),
+                                            getpid(),
+                                            size,
+                                            checksum);
+  int fd = open(dex_path.c_str(), O_WRONLY | O_CREAT | O_EXCL | O_CLOEXEC, 0600);
+  if (fd < 0) {
+    if (errno != EEXIST) {
+      PLOG(WARNING) << "pine ART dexdump open failed: " << dex_path;
+    }
+    return;
+  }
+
+  const uint8_t* cursor = begin;
+  size_t remaining = size;
+  bool ok = true;
+  while (remaining != 0u) {
+    const size_t chunk = std::min(remaining, static_cast<size_t>(1024 * 1024));
+    ssize_t written = write(fd, cursor, chunk);
+    if (written <= 0) {
+      PLOG(WARNING) << "pine ART dexdump write failed: " << dex_path;
+      ok = false;
+      break;
+    }
+    cursor += written;
+    remaining -= static_cast<size_t>(written);
+  }
+  close(fd);
+
+  if (!ok) {
+    unlink(dex_path.c_str());
+    return;
+  }
+
+  PineWriteDexMeta(dex_path + ".meta", dex_file, package_name, checksum);
+  LOG(INFO) << "pine ART dexdump wrote " << dex_path;
+}
