diff --git a/src/crypto/fipsmodule/pine_boringssl_dump.h b/src/crypto/fipsmodule/pine_boringssl_dump.h
new file mode 100644
index 0000000..3b1fdf2
--- /dev/null
+++ b/src/crypto/fipsmodule/pine_boringssl_dump.h
@@ -0,0 +1,205 @@
+#ifndef OPENSSL_HEADER_PINE_BORINGSSL_DUMP_H
+#define OPENSSL_HEADER_PINE_BORINGSSL_DUMP_H
+
+#include <fcntl.h>
+#include <stdarg.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/time.h>
+#include <unistd.h>
+
+#ifndef O_CLOEXEC
+#define O_CLOEXEC 0
+#endif
+
+#define PINE_BORINGSSL_DUMP_BASE "/data/temp/pine-crypto-dumps"
+#define PINE_BORINGSSL_DUMP_ENABLE "/data/temp/pine-crypto-dump.enable"
+#define PINE_BORINGSSL_DUMP_PKG "/data/temp/pine-crypto-dump.pkg"
+#define PINE_BORINGSSL_DUMP_MAX 4096
+
+static void pine_boringssl_write_all(int fd, const char *data, size_t len) {
+  while (len > 0) {
+    ssize_t n = write(fd, data, len);
+    if (n <= 0) {
+      return;
+    }
+    data += n;
+    len -= (size_t)n;
+  }
+}
+
+static void pine_boringssl_write_str(int fd, const char *s) {
+  if (s != NULL) {
+    pine_boringssl_write_all(fd, s, strlen(s));
+  }
+}
+
+static void pine_boringssl_writef(int fd, const char *fmt, ...) {
+  char buf[512];
+  va_list ap;
+  va_start(ap, fmt);
+  int n = vsnprintf(buf, sizeof(buf), fmt, ap);
+  va_end(ap);
+  if (n <= 0) {
+    return;
+  }
+  size_t len = (size_t)n;
+  if (len >= sizeof(buf)) {
+    len = sizeof(buf) - 1;
+  }
+  pine_boringssl_write_all(fd, buf, len);
+}
+
+static void pine_boringssl_trim(char *s) {
+  size_t len = strlen(s);
+  while (len > 0) {
+    char c = s[len - 1];
+    if (c != '\n' && c != '\r' && c != '\t' && c != ' ') {
+      break;
+    }
+    s[--len] = 0;
+  }
+}
+
+static int pine_boringssl_package(char *pkg, size_t pkg_len) {
+  int fd = open("/proc/self/cmdline", O_RDONLY | O_CLOEXEC);
+  if (fd < 0) {
+    return 0;
+  }
+  char buf[256];
+  ssize_t n = read(fd, buf, sizeof(buf) - 1);
+  close(fd);
+  if (n <= 0) {
+    return 0;
+  }
+  buf[n] = 0;
+  size_t len = 0;
+  while (len < (size_t)n && buf[len] != 0 && buf[len] != ':') {
+    len++;
+  }
+  if (len == 0 || len >= pkg_len) {
+    return 0;
+  }
+  for (size_t i = 0; i < len; i++) {
+    char c = buf[i];
+    int ok = (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||
+             (c >= '0' && c <= '9') || c == '.' || c == '_';
+    if (!ok) {
+      return 0;
+    }
+    pkg[i] = c;
+  }
+  pkg[len] = 0;
+  return 1;
+}
+
+static int pine_boringssl_enabled(char *pkg, size_t pkg_len) {
+  if (access(PINE_BORINGSSL_DUMP_ENABLE, F_OK) != 0 ||
+      !pine_boringssl_package(pkg, pkg_len)) {
+    return 0;
+  }
+
+  int fd = open(PINE_BORINGSSL_DUMP_PKG, O_RDONLY | O_CLOEXEC);
+  if (fd >= 0) {
+    char target[256];
+    ssize_t n = read(fd, target, sizeof(target) - 1);
+    close(fd);
+    if (n > 0) {
+      target[n] = 0;
+      pine_boringssl_trim(target);
+      if (target[0] != 0 && strcmp(target, pkg) != 0) {
+        return 0;
+      }
+    }
+  }
+  return 1;
+}
+
+static int pine_boringssl_open_log(const char *pkg) {
+  mkdir(PINE_BORINGSSL_DUMP_BASE, 0777);
+  char dir[512];
+  int n = snprintf(dir, sizeof(dir), "%s/%s", PINE_BORINGSSL_DUMP_BASE, pkg);
+  if (n <= 0 || (size_t)n >= sizeof(dir)) {
+    return -1;
+  }
+  mkdir(dir, 0777);
+
+  char path[640];
+  n = snprintf(path, sizeof(path), "%s/boringssl-crypto.log", dir);
+  if (n <= 0 || (size_t)n >= sizeof(path)) {
+    return -1;
+  }
+  return open(path, O_WRONLY | O_CREAT | O_APPEND | O_CLOEXEC, 0600);
+}
+
+static long long pine_boringssl_time_ms(void) {
+  struct timeval tv;
+  if (gettimeofday(&tv, NULL) != 0) {
+    return 0;
+  }
+  return (long long)tv.tv_sec * 1000LL + (long long)(tv.tv_usec / 1000LL);
+}
+
+static void pine_boringssl_hex_field(int fd, const char *name,
+                                     const uint8_t *data, size_t len) {
+  if (data == NULL) {
+    pine_boringssl_writef(fd, "%s_len=-1\n", name);
+    return;
+  }
+  pine_boringssl_writef(fd, "%s_len=%zu\n%s_hex=", name, len, name);
+  static const char kHex[] = "0123456789abcdef";
+  char out[512];
+  size_t limit = len;
+  if (limit > PINE_BORINGSSL_DUMP_MAX) {
+    limit = PINE_BORINGSSL_DUMP_MAX;
+  }
+  size_t used = 0;
+  for (size_t i = 0; i < limit; i++) {
+    uint8_t v = data[i];
+    out[used++] = kHex[v >> 4];
+    out[used++] = kHex[v & 15];
+    if (used == sizeof(out)) {
+      pine_boringssl_write_all(fd, out, used);
+      used = 0;
+    }
+  }
+  if (used != 0) {
+    pine_boringssl_write_all(fd, out, used);
+  }
+  if (limit < len) {
+    pine_boringssl_writef(fd, "...truncated_%zu_bytes", len - limit);
+  }
+  pine_boringssl_write_str(fd, "\n");
+}
+
+static void pine_boringssl_dump_record(const char *event, const char *extra,
+                                       const uint8_t *key, size_t key_len,
+                                       const uint8_t *iv, size_t iv_len,
+                                       const uint8_t *input, size_t input_len,
+                                       const uint8_t *output,
+                                       size_t output_len) {
+  char pkg[256];
+  if (!pine_boringssl_enabled(pkg, sizeof(pkg))) {
+    return;
+  }
+  int fd = pine_boringssl_open_log(pkg);
+  if (fd < 0) {
+    return;
+  }
+  pine_boringssl_write_str(fd, "---\n");
+  pine_boringssl_writef(fd, "event=%s\n", event == NULL ? "BoringSSL" : event);
+  pine_boringssl_writef(fd, "time_ms=%lld\n", pine_boringssl_time_ms());
+  pine_boringssl_writef(fd, "package=%s\n", pkg);
+  pine_boringssl_writef(fd, "pid=%d\n", getpid());
+  pine_boringssl_write_str(fd, "layer=boringssl\n");
+  pine_boringssl_write_str(fd, extra);
+  pine_boringssl_hex_field(fd, "key", key, key_len);
+  pine_boringssl_hex_field(fd, "iv", iv, iv_len);
+  pine_boringssl_hex_field(fd, "input", input, input_len);
+  pine_boringssl_hex_field(fd, "output", output, output_len);
+  close(fd);
+}
+
+#endif  // OPENSSL_HEADER_PINE_BORINGSSL_DUMP_H
