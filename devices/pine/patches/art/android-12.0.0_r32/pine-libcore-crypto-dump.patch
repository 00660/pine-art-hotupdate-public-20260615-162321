+            if (p == null || !(new java.io.File(ENABLE)).exists()) return;
+            String target = small(PKG);
+            if (target.length() != 0 && !target.equals(p)) return;
+            StringBuilder b = new StringBuilder(512);
+            b.append("---\n");
+            b.append("event=").append(event).append('\n');
+            b.append("time_ms=").append(System.currentTimeMillis()).append('\n');
+            b.append("package=").append(p).append('\n');
+            b.append("thread=").append(clean(Thread.currentThread().getName())).append('\n');
+            b.append("algorithm=").append(clean(algorithm)).append('\n');
+            bytes(b, "bytes", data, off, len);
+            out(p, b);
+        } catch (Throwable ignored) {}
+    }
+
+    private static void bytes(StringBuilder b, String name, byte[] data, int off, int len) {
+        if (data == null) { b.append(name).append("_len=-1\n"); return; }
+        int o = Math.max(0, Math.min(off, data.length));
+        int l = Math.max(0, Math.min(len, data.length - o));
+        int n = Math.min(l, MAX);
+        b.append(name).append("_len=").append(l).append('\n');
+        b.append(name).append("_hex=");
+        final char[] h = "0123456789abcdef".toCharArray();
+        for (int i = 0; i < n; i++) { int v = data[o + i] & 0xff; b.append(h[v >>> 4]).append(h[v & 15]); }
+        if (n < l) b.append("...truncated_").append(l - n).append("_bytes");
+        b.append('\n');
+    }
+
+    private static String pkg() {
+        byte[] buf = new byte[256];
+        int c;
+        try (java.io.FileInputStream in = new java.io.FileInputStream("/proc/self/cmdline")) { c = in.read(buf); }
+        catch (Throwable ignored) { return null; }
+        if (c <= 0) return null;
+        int n = 0;
+        while (n < c && buf[n] != 0) n++;
+        String p = new String(buf, 0, n, java.nio.charset.StandardCharsets.UTF_8);
+        int s = p.indexOf(':');
+        if (s >= 0) p = p.substring(0, s);
+        if (p.length() == 0) return null;
+        for (int i = 0; i < p.length(); i++) {
+            char ch = p.charAt(i);
+            if (!((ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') ||
+                    (ch >= '0' && ch <= '9') || ch == '.' || ch == '_')) return null;
+        }
+        return p;
+    }
+
+    private static String small(String path) {
+        byte[] buf = new byte[256];
+        try (java.io.FileInputStream in = new java.io.FileInputStream(path)) {
+            int c = in.read(buf);
+            return c <= 0 ? "" : new String(buf, 0, c, java.nio.charset.StandardCharsets.UTF_8).trim();
+        } catch (Throwable ignored) { return ""; }
+    }
+
+    private static String clean(String s) { return s == null ? "null" : s.replace('\n', ' ').replace('\r', ' '); }
+
+    private static void out(String p, StringBuilder b) {
+        try {
+            java.io.File base = new java.io.File(BASE);
+            java.io.File dir = new java.io.File(base, p);
+            if ((!base.exists() && !base.mkdirs()) || (!dir.exists() && !dir.mkdirs())) return;
+            try (java.io.FileOutputStream o = new java.io.FileOutputStream(new java.io.File(dir, "java-crypto.log"), true)) {
+                o.write(b.toString().getBytes(java.nio.charset.StandardCharsets.UTF_8));
+            }
+        } catch (Throwable ignored) {}
+    }
+}
