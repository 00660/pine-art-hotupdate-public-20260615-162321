+static bool pine_linker_prop_enabled(const char* key) {
+  std::string value = android::base::GetProperty(key, "");
+  return value == "1" || value == "true" || value == "y" ||
+         value == "yes" || value == "on";
+}
+
+static bool pine_linker_current_process_matches_target() {
+  if (!pine_linker_prop_enabled("debug.pine.native_hide") &&
+      !pine_linker_prop_enabled("persist.sys.pine_native_hide")) {
+    return false;
+  }
+
+  std::string target = android::base::GetProperty("debug.pine.hide_pkg", "");
+  if (target.empty()) {
+    target = android::base::GetProperty("persist.sys.pine_hide_pkg", "");
+  }
+  if (target.empty() || target == "*") {
+    return true;
+  }
+
+  char cmdline[256] = {};
+  int fd = open("/proc/self/cmdline", O_RDONLY | O_CLOEXEC);
+  if (fd < 0) {
+    return false;
+  }
+  ssize_t n = read(fd, cmdline, sizeof(cmdline) - 1);
+  close(fd);
+  if (n <= 0) {
+    return false;
+  }
+  cmdline[n] = '\0';
+
+  return target == cmdline ||
+         (strncmp(cmdline, target.c_str(), target.size()) == 0 &&
+          cmdline[target.size()] == ':');
+}
+
+static bool pine_linker_should_block_library(const char* name) {
+  if (name == nullptr || !pine_linker_current_process_matches_target()) {
+    return false;
+  }
+
+  static const char* const needles[] = {
+      "frida",
+      "xposed",
+      "lsposed",
+      "zygisk",
+      "riru",
+      "substrate",
+      "magisk",
+      "kernelsu",
+      "apatch",
+      nullptr,
+  };
+  for (size_t i = 0; needles[i] != nullptr; ++i) {
+    if (strstr(name, needles[i]) != nullptr) {
+      return true;
+    }
+  }
+  return false;
+}
