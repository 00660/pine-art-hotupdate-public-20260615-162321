+
 ssize_t readlink(const char* path, char* buf, size_t size) {
-  return readlinkat(AT_FDCWD, path, buf, size);
+  ssize_t result = readlinkat(AT_FDCWD, path, buf, size);
+  return __pine_bionic_filter_readlink_result(path, buf, size, result);
 }
