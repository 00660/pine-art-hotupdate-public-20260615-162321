diff --git a/libc/bionic/pine_antidetect.cpp b/libc/bionic/pine_antidetect.cpp
new file mode 100644
index 0000000..5816d36
--- /dev/null
+++ b/libc/bionic/pine_antidetect.cpp
@@ -0,0 +1,141 @@
+/*
+ * Pine target-scoped native anti-detection helpers.
+ */
+
+#include <errno.h>
+#include <fcntl.h>
+#include <string.h>
+#include <sys/system_properties.h>
+#include <unistd.h>
+
+extern "C" int __openat(int, const char*, int, int);
+
+static bool pine_str_eq(const char* a, const char* b) {
+  return strcmp(a, b) == 0;
+}
+
+static bool pine_str_has(const char* haystack, const char* needle) {
+  return haystack != nullptr && needle != nullptr && strstr(haystack, needle) != nullptr;
+}
+
+static bool pine_prop_enabled(const char* key) {
+  char value[PROP_VALUE_MAX] = {};
+  if (__system_property_get(key, value) <= 0) {
+    return false;
+  }
+  return pine_str_eq(value, "1") || pine_str_eq(value, "true") ||
+         pine_str_eq(value, "y") || pine_str_eq(value, "yes") ||
+         pine_str_eq(value, "on");
+}
+
+static void pine_get_target_package(char* value, size_t value_size) {
+  if (value_size == 0) {
+    return;
+  }
+  value[0] = '\0';
+  if (__system_property_get("debug.pine.hide_pkg", value) > 0) {
+    return;
+  }
+  __system_property_get("persist.sys.pine_hide_pkg", value);
+}
+
+static bool pine_current_process_matches_target() {
+  if (!pine_prop_enabled("debug.pine.native_hide") &&
+      !pine_prop_enabled("persist.sys.pine_native_hide")) {
+    return false;
+  }
+
+  char target[PROP_VALUE_MAX] = {};
+  pine_get_target_package(target, sizeof(target));
+  if (target[0] == '\0' || pine_str_eq(target, "*")) {
+    return true;
+  }
+
+  char cmdline[256] = {};
+  int fd = __openat(AT_FDCWD, "/proc/self/cmdline", O_RDONLY | O_CLOEXEC, 0);
+  if (fd < 0) {
+    return false;
+  }
+  ssize_t n = read(fd, cmdline, sizeof(cmdline) - 1);
+  close(fd);
+  if (n <= 0) {
+    return false;
+  }
+  cmdline[n] = '\0';
+
+  size_t target_len = strlen(target);
+  return strcmp(cmdline, target) == 0 ||
+         (strncmp(cmdline, target, target_len) == 0 && cmdline[target_len] == ':');
+}
+
+static bool pine_path_has_secret(const char* path) {
+  if (path == nullptr) {
+    return false;
+  }
+
+  static const char* const needles[] = {
+      "/data/adb",
+      "/debug_ramdisk",
+      "/sbin/.magisk",
+      "/system/bin/su",
+      "/system/xbin/su",
+      "/vendor/bin/su",
+      "/su/bin",
+      "magisk",
+      "zygisk",
+      "riru",
+      "lsposed",
+      "xposed",
+      "frida",
+      "substrate",
+      "kernelsu",
+      "apatch",
+      nullptr,
+  };
+
+  for (size_t i = 0; needles[i] != nullptr; ++i) {
+    if (pine_str_has(path, needles[i])) {
+      return true;
+    }
+  }
+  return false;
+}
+
+extern "C" bool __pine_bionic_should_hide_path(const char* path) {
+  return pine_current_process_matches_target() && pine_path_has_secret(path);
+}
+
+extern "C" int __pine_bionic_hidden_errno() {
+  errno = ENOENT;
+  return -1;
+}
+
+extern "C" ssize_t __pine_bionic_filter_readlink_result(const char* path,
+                                                        char* buf,
+                                                        size_t size,
+                                                        ssize_t result) {
+  if (result <= 0 || !pine_current_process_matches_target()) {
+    return result;
+  }
+  if (__pine_bionic_should_hide_path(path)) {
+    errno = ENOENT;
+    return -1;
+  }
+
+  char tmp[512];
+  size_t n = static_cast<size_t>(result);
+  if (n >= sizeof(tmp)) {
+    n = sizeof(tmp) - 1;
+  }
+  if (n > size) {
+    n = size;
+  }
+  memcpy(tmp, buf, n);
+  tmp[n] = '\0';
+
+  if (pine_path_has_secret(tmp)) {
+    errno = ENOENT;
+    return -1;
+  }
+  return result;
+}
