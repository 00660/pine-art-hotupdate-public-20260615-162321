+    private static boolean pinePropertyEnabled(String key) {
+        final String value = native_get(key, "");
+        return "1".equals(value) || "true".equals(value) || "y".equals(value)
+                || "yes".equals(value) || "on".equals(value);
+    }
+
+    private static boolean pineHideEnabledForProcess() {
+        if (!pinePropertyEnabled("debug.pine.framework_hide")
+                && !pinePropertyEnabled("persist.sys.pine_framework_hide")) {
+            return false;
+        }
+
+        String target = native_get("debug.pine.hide_pkg", "");
+        if (target.isEmpty()) {
+            target = native_get("persist.sys.pine_hide_pkg", "");
+        }
+        if (target.isEmpty() || "*".equals(target)) {
+            return true;
+        }
+
+        try {
+            final String packageName = android.app.ActivityThread.currentPackageName();
+            return target.equals(packageName)
+                    || (packageName != null && packageName.startsWith(target + ":"));
+        } catch (Throwable ignored) {
+            return false;
+        }
+    }
+
+    private static String pineSpoofProperty(String key) {
+        if (key == null || !pineHideEnabledForProcess()) {
+            return null;
+        }
+        switch (key) {
+            case "ro.debuggable":
+            case "ro.adb.secure":
+            case "ro.boot.flash.locked":
+            case "ro.boot.warranty_bit":
+            case "ro.boot.veritymode":
+            case "ro.boot.verifiedbootstate":
+            case "ro.boot.vbmeta.device_state":
+            case "ro.build.type":
+            case "ro.build.tags":
+            case "ro.secure":
+            case "service.adb.root":
+                break;
+            default:
+                return null;
+        }
+
+        if ("ro.debuggable".equals(key) || "service.adb.root".equals(key)
+                || "ro.boot.warranty_bit".equals(key)) {
+            return "0";
+        }
+        if ("ro.secure".equals(key) || "ro.adb.secure".equals(key)
+                || "ro.boot.flash.locked".equals(key)) {
+            return "1";
+        }
+        if ("ro.boot.verifiedbootstate".equals(key)) {
+            return "green";
+        }
+        if ("ro.boot.vbmeta.device_state".equals(key)) {
+            return "locked";
+        }
+        if ("ro.boot.veritymode".equals(key)) {
+            return "enforcing";
+        }
+        if ("ro.build.type".equals(key)) {
+            return "user";
+        }
+        if ("ro.build.tags".equals(key)) {
+            return "release-keys";
+        }
+        return null;
+    }
