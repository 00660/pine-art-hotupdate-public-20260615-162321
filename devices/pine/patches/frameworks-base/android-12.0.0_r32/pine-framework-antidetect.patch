+    private static boolean pineHideEnabledForProcess() {
+        if (!SystemProperties.getBoolean("debug.pine.framework_hide", false)
+                && !SystemProperties.getBoolean("persist.sys.pine_framework_hide", false)) {
+            return false;
+        }
+        String target = SystemProperties.get("debug.pine.hide_pkg", "");
+        if (target.isEmpty()) {
+            target = SystemProperties.get("persist.sys.pine_hide_pkg", "");
+        }
+        if (target.isEmpty() || "*".equals(target)) {
+            return true;
+        }
+        final String packageName = ActivityThread.currentPackageName();
+        return target.equals(packageName)
+                || (packageName != null && packageName.startsWith(target + ":"));
+    }
+
+    private static boolean pineShouldHidePackage(String packageName) {
+        if (packageName == null || !pineHideEnabledForProcess()) {
+            return false;
+        }
+        final String normalized = packageName.toLowerCase();
+        for (String token : PINE_HIDDEN_PACKAGE_TOKENS) {
+            if (normalized.contains(token)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    private static String[] pineFilterPackageNames(String[] packages) {
+        if (packages == null || !pineHideEnabledForProcess()) {
+            return packages;
+        }
+        final ArrayList<String> filtered = new ArrayList<>(packages.length);
+        for (String packageName : packages) {
+            if (!pineShouldHidePackage(packageName)) {
+                filtered.add(packageName);
+            }
+        }
+        return filtered.toArray(new String[filtered.size()]);
+    }
+
+    private static List<PackageInfo> pineFilterPackageInfoList(List<PackageInfo> packages) {
+        if (packages == null || packages.isEmpty() || !pineHideEnabledForProcess()) {
+            return packages;
+        }
+        final ArrayList<PackageInfo> filtered = new ArrayList<>(packages.size());
+        for (PackageInfo info : packages) {
+            if (info == null || !pineShouldHidePackage(info.packageName)) {
+                filtered.add(info);
+            }
+        }
+        return filtered;
+    }
+
+    private static List<ApplicationInfo> pineFilterApplicationInfoList(
+            List<ApplicationInfo> applications) {
+        if (applications == null || applications.isEmpty() || !pineHideEnabledForProcess()) {
+            return applications;
+        }
+        final ArrayList<ApplicationInfo> filtered = new ArrayList<>(applications.size());
+        for (ApplicationInfo info : applications) {
+            if (info == null || !pineShouldHidePackage(info.packageName)) {
+                filtered.add(info);
+            }
+        }
+        return filtered;
+    }
